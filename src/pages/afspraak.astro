---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'

const base = import.meta.env.BASE_URL
---

<BaseLayout
  title="Plan een afspraak"
  description="Plan direct een kennismakingsgesprek met voedingscoach Shyla via mijn agenda."
>
  <Breadcrumb items={[{ name: 'Home', href: '' }, { name: 'Afspraak' }]} />

  <section class="contact-section">
    <div class="container">
      <div class="contact-grid contact-grid--reverse contact-grid--widget-first">
        <aside class="contact-aside">
          <div class="contact-card">
            <div class="contact-card-image">
              <img src={`${base}images/shyla/sfeer-116.jpg`} alt="Shyla, voedingscoach" />
            </div>
            <div class="contact-card-body">
              <h3>Liever eerst even kletsen?</h3>
              <p>Heb je vragen voor je een afspraak inplant? Stuur me gerust een bericht en we kijken samen wat er bij jou past.</p>
              <a href={`${base}contact`} class="btn btn-outline">Stel een vraag</a>
            </div>
          </div>
        </aside>

        <div>
          <div class="s-head">
            <span class="eyebrow">Aan de slag</span>
            <h1>Plan je <em>afspraak</em></h1>
            <p>Kies een moment dat jou uitkomt. We starten met een gratis kennismaking, daarna kijken we samen wat er bij jou past.</p>
          </div>

          <div class="contact-form-wrap afspraak-widget-wrap">
            <vg-guest-booking widget-key="6a00e55518088a6692e1a9c6" club-id="100302" lang="nl" source=""></vg-guest-booking>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline src="https://static.virtuagym.com/vg-guest-booking-widget/dist/js/app.js"></script>
</BaseLayout>
