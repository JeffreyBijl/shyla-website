---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'

const base = import.meta.env.BASE_URL
---

<BaseLayout
  title="Samenwerkingen"
  description="Informatie over samenwerkingen met voedingscoach Shyla."
>
  <Breadcrumb items={[{ name: 'Home', href: '' }, { name: 'Samenwerkingen' }]} />

  <section class="section section--tight">
    <div class="container" style="max-width: 720px;">
      <div class="s-head center">
        <span class="eyebrow center">Partners</span>
        <h1>Samen<em>werkingen</em></h1>
        <p>Samen bereiken we meer.</p>
      </div>
      <p style="font-size: 1.05rem; text-align: center; max-width: 560px; margin: 0 auto 32px;">
        Ik werk graag samen met merken en bedrijven die passen bij mijn visie op gezond en lekker eten. Heb je een leuk voorstel? Neem dan gerust contact met mij op!
      </p>
      <div style="display: flex; justify-content: center;">
        <a href={`${base}contact`} class="btn btn-pink">
          Neem contact op
          <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
