---
import BaseLayout from '../layouts/BaseLayout.astro'

const base = import.meta.env.BASE_URL
const siteUrl = Astro.site?.origin ?? ''

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: '1-op-1 voedingscoaching',
  serviceType: 'Voedingscoaching',
  description:
    'Persoonlijke voedingscoaching met wekelijkse check-ins, een plan op maat, toegang tot een coaching-app met workouts, en elke twee weken een 1-op-1 call. Geen strenge diëten, met focus op duurzame balans, emotie-eten en blijvende verandering.',
  provider: {
    '@type': 'Person',
    name: 'Shyla',
    jobTitle: 'Voedingscoach',
    url: `${siteUrl}${base}over-mij`,
  },
  areaServed: {
    '@type': 'Country',
    name: 'Nederland',
  },
  audience: {
    '@type': 'Audience',
    audienceType: 'Volwassenen met focus op duurzame leefstijlverandering, emotie-eten of binge-eating',
  },
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'EUR',
    name: 'Gratis kennismakingsgesprek',
    description: 'Vrijblijvend kennismakingsgesprek om te kijken of het klikt en welk traject past.',
    url: `${siteUrl}${base}afspraak`,
  },
  url: `${siteUrl}${base}`,
}
---

<BaseLayout
  title="Voedingscoach Shyla · Gezond & lekker eten"
  description="Voedingscoach Shyla helpt je een gezonde lifestyle op te bouwen zonder strenge diëten, met focus op balans, emotie-eten en duurzame verandering."
  extraSchemas={[serviceSchema]}
>
  <!-- ── Hero ── -->
  <section class="hero">
    <div class="container">
      <div class="hero-grid">
        <div class="hero-text">
          <span class="eyebrow">Voedingscoach · Persoonlijk</span>
          <h1>
            Eet lekker.
            <span class="accent">Leef gezond.</span>
          </h1>
          <p class="hero-lede">
            Gezond leven hoeft niet saai, streng of ingewikkeld te zijn. Sterker nog, het mag leuk zijn. Ik help je een lifestyle bouwen die echt bij jou past, en die je ook volhoudt.
          </p>
          <div class="hero-actions">
            <a href={`${base}afspraak`} class="btn btn-primary">
              Plan een kennismaking
              <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
              </svg>
            </a>
            <a href={`${base}over-mij`} class="btn btn-outline">Mijn verhaal</a>
          </div>
          <div class="hero-meta">
            <div class="hero-meta-item">
              <span class="hero-meta-pillar">Gezonde recepten</span>
              <span class="hero-meta-label">· Voor elke dag</span>
            </div>
            <div class="hero-meta-item">
              <span class="hero-meta-pillar">Klanttevredenheid</span>
              <span class="hero-meta-label">· Altijd voorop</span>
            </div>
            <div class="hero-meta-item">
              <span class="hero-meta-pillar">Persoonlijke aanpak</span>
              <span class="hero-meta-label">· Op jouw tempo</span>
            </div>
          </div>
        </div>

        <div class="hero-image">
          <img src={`${base}images/shyla/hero.jpg`} alt="Shyla, voedingscoach" />
          <div class="hero-image-tag">
            <span class="hero-image-tag-dot" aria-hidden="true"></span>
            Gecertificeerd voedingscoach
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Features ── -->
  <section class="section features">
    <div class="container">
      <div class="s-head center">
        <span class="eyebrow center">Wat ik bied</span>
        <h2>Alles voor een <span class="accent">gezonde leefstijl</span></h2>
        <p>Persoonlijke coaching, eerlijke recepten en kennis die je écht verder helpt.</p>
      </div>

      <div class="features-grid features-grid--two">
        <div class="feature feature--accent">
          <span class="feature-num">01 · Coaching</span>
          <h3>1-op-1 begeleiding</h3>
          <p>Persoonlijk, betrokken en zonder oordeel. Wekelijkse check-ins en een plan dat bij jou past.</p>
          <a href={`${base}afspraak`} class="btn-ghost">
            Plan kennismaking
            <svg class="btn-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        </div>
        <div class="feature">
          <span class="feature-num">02 · Blog</span>
          <h3>Eerlijke kennis</h3>
          <p>Artikelen over voeding, emotie-eten en leefstijl, geschreven vanuit eigen ervaring.</p>
          <a href={`${base}blog`} class="btn-ghost">
            Lees de blog
            <svg class="btn-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ── CTA banner ── -->
  <section class="section cta">
    <div class="container">
      <div class="cta-grid">
        <div class="cta-body">
          <span class="eyebrow">Samenwerken</span>
          <h2 style="margin-top: 18px;">Klaar om te <span class="accent">beginnen?</span></h2>
          <p>Je hoeft het niet alleen te doen. Ik loop met je mee, stap voor stap, eerlijk en zonder oordeel. Op jouw manier.</p>
          <a href={`${base}afspraak`} class="btn btn-pink">
            Plan je afspraak
            <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
        </div>
        <div class="cta-image cta-image--portrait">
          <img src={`${base}images/shyla/sfeer-43.jpg`} alt="Shyla in de keuken" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
