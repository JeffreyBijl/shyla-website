---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'

const base = import.meta.env.BASE_URL
const faqs = [
  {
    question: 'Moet ik een streng dieet volgen?',
    answer: 'Nee. Ik geloof niet in strenge diëten of vaste regels. Je gaat juist leren eten op een manier die bij jou past, met ruimte voor dingen die je lekker vindt. Het doel is dat je dit volhoudt voor de lange termijn.',
  },
  {
    question: 'Krijg ik een maaltijdschema?',
    answer: 'In de basis werk ik niet met standaard maaltijdschema’s, omdat ik geloof dat die vaak niet duurzaam zijn.\n\nWel kijk ik altijd naar jouw persoonlijke behoefte. Heb jij juist behoefte aan meer structuur en houvast, dan kunnen we (tijdelijk) werken met een maaltijdschema. Voor iedereen werkt iets anders, en daar speel ik op in.\n\nDaarnaast krijg je inzicht in jouw calorieën en macro’s, zodat je vrijheid hebt in wat je eet, zonder de grip te verliezen.',
  },
  {
    question: 'Helpt dit ook als ik last heb van emotie-eten of binge-eating?',
    answer: 'Ja, juist. Dit is een belangrijk onderdeel van mijn coaching. We gaan samen kijken waar het vandaan komt en hoe je deze patronen stap voor stap doorbreekt, zonder schuldgevoel of extreme regels.',
  },
  {
    question: 'Is jouw coaching alleen voor afvallen?',
    answer: 'Nee. Je kunt bij mij terecht als je wilt afvallen, aankomen of gewoon een betere relatie met voeding wilt ontwikkelen. Het gaat uiteindelijk om balans en een lifestyle die bij jou past.',
  },
  {
    question: 'Hoe ziet de begeleiding eruit?',
    answer: 'Je krijgt 1-op-1 coaching met wekelijkse check-ins, toegang tot mijn app, persoonlijke begeleiding en elke 2 weken een call. Tussendoor kun je altijd contact met mij opnemen als je vragen hebt of ergens tegenaan loopt.',
  },
  {
    question: 'Moet ik sporten?',
    answer: 'Sporten is geen verplichting, maar het kan wel een mooie toevoeging zijn. Ik help je met workouts die passen bij jouw niveau en leven, maar we kijken vooral naar wat voor jou haalbaar en leuk is.',
  },
  {
    question: 'Hoe snel zie ik resultaat?',
    answer: 'Dat verschilt per persoon. We richten ons niet op snelle oplossingen, maar op blijvende verandering. Juist daardoor zul je merken dat resultaten niet alleen komen, maar ook blijven.',
  },
  {
    question: 'Wat als ik het een keer “niet goed” doe?',
    answer: 'Dat hoort erbij. Er bestaat geen perfect. Juist die momenten zijn waardevol, want daar leren we van. Je hoeft het niet alleen op te lossen, ik help je weer terug in balans te komen zonder schuldgevoel.',
  },
  {
    question: 'Is het geschikt als ik een druk leven heb?',
    answer: 'Ja. Juist dan. We bouwen een aanpak die past in jouw leven, niet andersom. Geen ingewikkelde schema’s, maar iets wat jij echt kunt volhouden.',
  },
  {
    question: 'Hoe weet ik of dit bij mij past?',
    answer: 'We starten altijd met een kennismakingsgesprek. Tijdens dit gesprek kijken we of er een klik is, want dat is ontzettend belangrijk. Als jij je niet op je gemak voelt of niet eerlijk durft te zijn, gaat de coaching niet werken.\n\nZijn we allebei enthousiast na de kennismaking, dan kijken we samen welk plan het beste bij jou past en wat jij nodig hebt.\n\nDat kan een maand zijn, meerdere maanden of zelfs een jaar. Alles is maatwerk en kan ook altijd verlengd worden. We stemmen samen af wat het beste aansluit bij jouw doelen en jouw leven.',
  },
]

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
}
---

<BaseLayout
  title="Veelgestelde Vragen"
  description="Antwoorden op veelgestelde vragen over voeding, gezond eten en samenwerking met voedingscoach Shyla."
  extraSchemas={[faqSchema]}
>
  <Breadcrumb items={[{ name: 'Home', href: '' }, { name: 'Veelgestelde vragen' }]} />

  <section class="contact-section">
    <div class="container">
      <div class="s-head center" style="margin-bottom: 16px;">
        <span class="eyebrow center">FAQ</span>
        <h1>Veelgestelde <em>vragen</em></h1>
        <p>Antwoorden op de meest gestelde vragen over coaching en voeding.</p>
      </div>

      <div class="contact-grid contact-grid--reverse">
        <aside class="contact-aside">
          <div class="contact-card">
            <div class="contact-card-image">
              <img src={`${base}images/shyla/sfeer-74.jpg`} alt="Shyla" />
            </div>
            <div class="contact-card-body">
              <h3>Vraag staat er niet bij?</h3>
              <p>Stel jouw vraag gerust persoonlijk. Ik antwoord doorgaans binnen 1-2 werkdagen.</p>
              <a href={`${base}contact`} class="btn btn-pink">
                Neem contact op
                <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
                </svg>
              </a>
            </div>
          </div>
        </aside>

        <div class="faq-list">
          {faqs.map(faq => (
            <details class="faq-item">
              <summary>{faq.question}</summary>
              {faq.answer.split('\n\n').map(p => <p>{p}</p>)}
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
