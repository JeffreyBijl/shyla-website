---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import BlogCard from '../../components/BlogCard.astro'
import blogData from '../../data/blog.json'
import type { BlogPost } from '../../data/types.ts'

// Meest recente artikel eerst (bovenaan op mobiel, linksboven op desktop)
const blogPosts: BlogPost[] = [...(blogData as BlogPost[])].sort((a, b) => b.date.localeCompare(a.date))
---

<BaseLayout
  title="Blog over Voeding & Gezondheid"
  description="Artikelen over voeding, leefstijl en gezond leven door voedingscoach Shyla."
>
  <Breadcrumb items={[{ name: 'Home', href: '' }, { name: 'Blog' }]} />

  <section class="section section--tight">
    <div class="container">
      <div class="s-head center">
        <span class="eyebrow center">Lezen &amp; leren</span>
        <h1>De <em>blog</em></h1>
        <p>Eerlijke artikelen over voeding, leefstijl en alles wat erbij komt kijken, vanuit eigen ervaring.</p>
      </div>

      <div class="recipe-grid">
        {blogPosts.map((post, i) => <BlogCard post={post} index={i} />)}
      </div>
    </div>
  </section>
</BaseLayout>
