---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'

const base = import.meta.env.BASE_URL
---

<BaseLayout
  title="Tarieven"
  description="Bekijk de tarieven en coachingspakketten van voedingscoach Shyla en kies het plan dat bij jou past."
>
  <Breadcrumb items={[{ name: 'Home', href: '' }, { name: 'Tarieven' }]} />

  <section class="contact-section">
    <div class="container">
      <div class="s-head center" style="margin-bottom: 24px;">
        <span class="eyebrow center">Tarieven</span>
        <h1>Kies je <em>plan</em></h1>
        <p>Bekijk de coachingspakketten en kies wat bij jouw doelen en leven past. Niet zeker welk plan? Plan een gratis kennismaking en we kijken samen wat het beste aansluit.</p>
      </div>

      <div class="tarieven-frame-wrap">
        <iframe
          id="tarieven-frame"
          src="https://fitfoodbyshyla.virtuagym.com/webshop/?club=TFJiTlA1bWs4WFpiakNFQlYrU3kyUT09&embedded=1"
          title="Tarieven en pakketten van fit.foodbyshyla"
          loading="lazy"
          scrolling="auto"
        ></iframe>
      </div>

      <div class="tarieven-cta">
        <p>Twijfel je nog over welk plan bij je past?</p>
        <a href={`${base}afspraak`} class="btn btn-pink">
          Plan een gratis kennismaking
          <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /*
   * De webshop wordt opgesloten in een vak met vaste hoogte, zodat een interne
   * navigatie of focus in de iframe nooit de hele pagina kan wegtrekken.
   *
   * Cruciaal voor iOS (Safari én Chrome draaien op WebKit): WebKit laat een
   * iframe in de normale flow uitdijen tot de volledige inhoudshoogte, en
   * overflow op de ouder houdt dat in Chrome niet tegen. Daarom positioneren we
   * de iframe ABSOLUUT binnen de container: zo staat hij buiten de flow en kan
   * hij de pagina niet langer maken, terwijl height:100% wel wordt afgedwongen.
   * De iframe scrollt intern (scrolling=auto). Hoogte in dvh zodat het vak met
   * de adresbalk van mobiele browsers meebeweegt.
   */
  .tarieven-frame-wrap {
    position: relative;
    max-width: 820px;
    margin-inline: auto;
    background: var(--white, #FFFCF7);
    border-radius: 18px;
    box-shadow: 0 18px 48px rgba(74, 58, 44, 0.08);
    overflow: hidden;
    height: min(82vh, 1000px);
    height: min(82dvh, 1000px);
  }

  .tarieven-frame-wrap iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    -webkit-overflow-scrolling: touch;
  }

  @media (max-width: 720px) {
    .tarieven-frame-wrap {
      height: min(78vh, 760px);
      height: min(78dvh, 760px);
    }
  }

  .tarieven-cta {
    text-align: center;
    margin-top: 36px;
  }

  .tarieven-cta p {
    margin: 0 0 14px;
    color: var(--ink-soft, #5B4E45);
  }
</style>
