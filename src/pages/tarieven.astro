---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'

const base = import.meta.env.BASE_URL
---

<BaseLayout
  title="Tarieven"
  description="Bekijk de tarieven en coachingspakketten van voedingscoach Shyla en kies het plan dat bij jou past."
>
  <Breadcrumb items={[{ name: 'Home', href: '' }, { name: 'Tarieven' }]} />

  <section class="contact-section">
    <div class="container">
      <div class="s-head center" style="margin-bottom: 24px;">
        <span class="eyebrow center">Tarieven</span>
        <h1>Kies je <em>plan</em></h1>
        <p>Bekijk de coachingspakketten en kies wat bij jouw doelen en leven past. Niet zeker welk plan? Plan een gratis kennismaking en we kijken samen wat het beste aansluit.</p>
      </div>

      <div class="tarieven-frame-wrap">
        <iframe
          id="tarieven-frame"
          src="https://fitfoodbyshyla.virtuagym.com/webshop/?club=TFJiTlA1bWs4WFpiakNFQlYrU3kyUT09&embedded=1"
          title="Tarieven en pakketten van fit.foodbyshyla"
          loading="lazy"
          scrolling="no"
        ></iframe>
      </div>

      <div class="tarieven-cta">
        <p>Twijfel je nog over welk plan bij je past?</p>
        <a href={`${base}afspraak`} class="btn btn-pink">
          Plan een gratis kennismaking
          <svg class="btn-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="5" y1="12" x2="19" y2="12" /><polyline points="12 5 19 12 12 19" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <script is:inline>
    // Virtuagym stuurt (soms) zijn inhoudshoogte via postMessage. Vangen we die op,
    // dan zetten we de iframe exact zo hoog zodat er nooit een interne scrollbar is.
    // Zonder bericht blijft de vaste hoogte uit de CSS als fallback gelden.
    (function () {
      var frame = document.getElementById('tarieven-frame')
      if (!frame) return
      window.addEventListener('message', function (e) {
        if (typeof e.origin === 'string' && e.origin.indexOf('virtuagym.com') === -1) return
        var d = e.data
        var h
        if (typeof d === 'number') h = d
        else if (typeof d === 'string') { try { var o = JSON.parse(d); h = o.height || o.iframeHeight || o.scrollHeight } catch (err) {} }
        else if (d && typeof d === 'object') h = d.height || d.iframeHeight || d.scrollHeight || (d.payload && d.payload.height)
        h = Number(h)
        if (h > 200) frame.style.height = h + 'px'
      })
    })()
  </script>
</BaseLayout>

<style>
  .tarieven-frame-wrap {
    max-width: 820px;
    margin-inline: auto;
    background: var(--white, #FFFCF7);
    border-radius: 18px;
    box-shadow: 0 18px 48px rgba(74, 58, 44, 0.08);
    overflow: hidden;
  }

  .tarieven-frame-wrap iframe {
    display: block;
    width: 100%;
    height: 1440px;
    border: none;
  }

  @media (max-width: 720px) {
    .tarieven-frame-wrap iframe {
      height: 2600px;
    }
  }

  .tarieven-cta {
    text-align: center;
    margin-top: 36px;
  }

  .tarieven-cta p {
    margin: 0 0 14px;
    color: var(--ink-soft, #5B4E45);
  }
</style>
