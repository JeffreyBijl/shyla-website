---
import type { BlogPost } from '../data/types.ts'
import blogData from '../data/blog.json'

interface Props {
  type: 'recipe' | 'blog'
  currentSlug: string
}

const { type, currentSlug } = Astro.props
const base = import.meta.env.BASE_URL
const blogPosts = blogData as BlogPost[]

// Altijd doorlinken naar blog-artikelen (recepten-pagina is niet meer in gebruik),
// meest recente eerst en het huidige artikel uitgesloten.
const items = blogPosts
  .filter(p => p.slug !== currentSlug)
  .sort((a, b) => b.date.localeCompare(a.date))
  .slice(0, 3)
  .map(p => ({
    title: p.title,
    href: `${base}blog/${p.slug}`,
    description: p.shortDescription,
  }))
---

{items.length > 0 && (
  <section class="section related-content">
    <div class="container">
      <h2>{type === 'recipe' ? 'Gerelateerde artikelen' : 'Lees ook deze artikelen'}</h2>
      <div class="grid-3">
        {items.map(item => (
          <a href={item.href} class="card related-content-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
