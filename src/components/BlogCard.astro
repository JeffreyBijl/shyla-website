---
import type { BlogPost } from '../data/types.ts'
import { formatDateDutch } from '../utils/formatting.ts'

interface Props {
  post: BlogPost
  index?: number
}

const { post } = Astro.props
const base = import.meta.env.BASE_URL
---

<a href={`${base}blog/${post.slug}`} class="recipe-card-link">
  <article class="recipe-card">
    <div class="recipe-photo recipe-photo--portrait">
      {post.image ? (
        <img src={`${base}${post.image}`} alt={post.title} loading="lazy" />
      ) : (
        <div class="recipe-photo-fallback" aria-hidden="true">📝</div>
      )}
      <span class="recipe-tag">{post.category}</span>
    </div>
    <div class="recipe-body">
      <div style="font-size: 0.78rem; color: var(--ink-mute); letter-spacing: 0.04em;">
        {formatDateDutch(post.date)} · {post.readTime} leestijd
      </div>
      <h3>{post.title}</h3>
      <p>{post.shortDescription}</p>
      <span class="btn-ghost" style="font-size: 0.85rem; align-self: flex-start; margin-top: 4px;">
        Lees verder
        <svg class="btn-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="5" y1="12" x2="19" y2="12" />
          <polyline points="12 5 19 12 12 19" />
        </svg>
      </span>
    </div>
  </article>
</a>
