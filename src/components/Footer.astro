---
const base = import.meta.env.BASE_URL
const year = new Date().getFullYear()
---

<footer class="footer">
  <div class="container">

    <div class="footer-grid">
      <div class="footer-brand">
        <p class="footer-tagline">
          Eet lekker, leef gezond. Een voedingscoach die met je meeloopt — zonder strenge diëten, met focus op balans en plezier.
        </p>
        <div class="footer-socials">
          <a href="https://instagram.com/fit.foodbyshyla" target="_blank" rel="noopener" aria-label="Instagram" class="footer-social">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
          <a href="mailto:info@fitfoodbyshyla.nl" aria-label="E-mail" class="footer-social">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </a>
        </div>
      </div>
      <div class="footer-col">
        <h4>Ontdek</h4>
        <ul role="list">
          <li><a href={`${base}over-mij`}>Over mij</a></li>
          <li><a href={`${base}blog`}>Blog</a></li>
          <li><a href={`${base}faq`}>FAQ</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Aan de slag</h4>
        <ul role="list">
          <li><a href={`${base}afspraak`}>Plan afspraak</a></li>
          <li><a href={`${base}contact`}>Contact</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Contact</h4>
        <ul role="list">
          <li><a href="mailto:info@fitfoodbyshyla.nl">info@fitfoodbyshyla.nl</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© {year} fit.foodbyshyla — Alle rechten voorbehouden</span>
      <span>Gemaakt met liefde voor balans</span>
    </div>
  </div>
</footer>
