---
import type { Recipe } from '../data/types.ts'

interface Props {
  recipe: Recipe
}

const { recipe } = Astro.props
const base = import.meta.env.BASE_URL

const categoryLabel = recipe.category.charAt(0).toUpperCase() + recipe.category.slice(1)
---

<a href={`${base}recepten/${recipe.slug}`} class="recipe-card-link" data-category={recipe.category}>
  <article class="recipe-card">
    <div class="recipe-photo">
      {recipe.image ? (
        <img src={`${base}${recipe.image}`} alt={recipe.title} loading="lazy" />
      ) : (
        <div class="recipe-photo-fallback" aria-hidden="true">{recipe.emoji || '🍽️'}</div>
      )}
      <span class="recipe-tag">{categoryLabel}</span>
    </div>
    <div class="recipe-body">
      <h3>{recipe.title}</h3>
      <p>{recipe.description}</p>
      <div class="recipe-meta">
        <span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
          </svg>
          {recipe.time}
        </span>
        {recipe.servings && (
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" />
            </svg>
            {recipe.servings} pers
          </span>
        )}
        {recipe.nutrition && recipe.nutrition.kcal > 0 && (
          <span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z" />
            </svg>
            {recipe.nutrition.kcal} kcal
          </span>
        )}
      </div>
    </div>
  </article>
</a>
