# Kopieer dit bestand naar .env.deploy en vul de TransIP-gegevens in.
# .env.deploy zit in .gitignore en komt nooit op GitHub terecht.
#
# De gegevens vind je in TransIP > Webhostingpakket > SFTP/SSH.

SFTP_HOST=fitfp6.ssh.transip.me
SFTP_PORT=22
SFTP_USER=fitfoodbyshylanl
SFTP_PASS=JOUW_SFTP_WACHTWOORD

# Pad naar de webroot op de server (waar index.html komt te staan).
# Op TransIP shared hosting standaard:
SFTP_REMOTE_PATH=/domains/fitfoodbyshyla.nl/public_html
